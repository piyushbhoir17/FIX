#
# Fingerprint driver configuration
#

if MACH_ASUS_SDM660

menuconfig INPUT_FINGERPRINT
	bool "Fingerprint"
	help
	  Say Y here, and a list of supported fingerprint will be displayed.
	  This option doesn't affect the kernel.

	  If unsure, say Y.

if INPUT_FINGERPRINT

source "drivers/input/fingerprint/cdfingerfp/Kconfig"

source "drivers/input/fingerprint/focaltech/Kconfig"

config GOODIX_FP_X00TD
	bool "Fingerprint goodix"
	depends on MACH_ASUS_X00TD
	help
	  Say Y here if you use common fp.
	  If unsure, say N.

endif

endif
