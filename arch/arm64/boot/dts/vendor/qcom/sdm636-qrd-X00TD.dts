/dts-v1/;
#include "sdm636.dtsi"
#include "sdm636-qrd.dtsi"
#include "sdm660-internal-codec.dtsi"

#include "X00TD/sdm636-overlay.dtsi"
#include "X00TD/sdm636-qrd-overlay.dtsi"
#include "X00TD/sdm660-internal-codec-overlay.dtsi"
#include "X00TD/sdm660-external-codec-overlay.dtsi"

/ {
	model = "Qualcomm Technologies, Inc. SDM 636 PM660 + PM660L QRD";
	compatible = "qcom,sdm636-qrd", "qcom,sdm636", "qcom,qrd";
	qcom,board-id = <0x1000b 0>;
	qcom,pmic-id = <0x0001001b 0x0101011a 0x0 0x0>,
			<0x0001001b 0x0201011a 0x0 0x0>,
			<0x0001001b 0x0102001a 0x0 0x0>;
};

&mdss_mdp {
	qcom,mdss-pref-prim-intf = "dsi";
};

&mdss_dsi {
	hw-config = "single_dsi";
	qcom,mdss-fb-map-prim = <&mdss_fb0>;
	qcom,mdss-fb-map-sec = <&mdss_fb2>;
};

&dsi_panel_pwr_supply {
	qcom,panel-supply-entry@0 {
	qcom,supply-pre-off-sleep = <2>;
	};
};

&mdss_dsi0 {
	qcom,dsi-pref-prim-pan = <&dsi_nt36672_1080p_video_txd>;
	pinctrl-names = "mdss_default", "mdss_sleep";
	pinctrl-0 = <&mdss_dsi_active &mdss_te_active>;
	pinctrl-1 = <&mdss_dsi_suspend &mdss_te_suspend>;
	qcom,platform-reset-gpio = <&tlmm 53 0>;
	qcom,platform-te-gpio = <&tlmm 59 0>;
};

&mdss_dsi1 {
	status = "disabled";
};

&dsi_dual_nt36850_truly_cmd {
	qcom,mdss-dsi-bl-pmic-control-type = "bl_ctrl_wled";
	qcom,mdss-dsi-bl-min-level = <1>;
	qcom,mdss-dsi-bl-max-level = <4095>;
	qcom,panel-supply-entries = <&dsi_panel_pwr_supply>;
};

&pm660l_wled {
	qcom,string-cfg = <3>;
};

&dsi_nt36672_1080p_video_txd {
	qcom,panel-supply-entries = <&dsi_panel_pwr_supply>;
};

&dsi_nt36672_1080p_video {
	qcom,panel-supply-entries = <&dsi_panel_pwr_supply>;
};

&dsi_td4310_1080p_video_txd {
	qcom,panel-supply-entries = <&dsi_panel_pwr_supply>;
};

&soc {
	cdfinger_fp {
		compatible = "cdfinger,fingerprint";
		interrupt-parent = <&tlmm>;
		interrupts = <72 IRQ_TYPE_EDGE_RISING>;
		cdfinger,reset_gpio = <&tlmm 20 GPIO_ACTIVE_LOW>;
		cdfinger,irq_gpio = <&tlmm 72 GPIO_ACTIVE_HIGH>;
		cdfinger,gpio_vdd = <&pm660l_gpios 5 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "cdfinger_active", "cdfinger_sleep";
		pinctrl-0 = <&cdfinger_reset_active &cdfinger_irq_active>;
		pinctrl-1 = <&cdfinger_reset_sleep &cdfinger_irq_sleep>;
	};

	goodix_fingerprint {
		compatible = "goodix,fingerprint";
		interrupt-parent = <&tlmm>;
		interrupts = <72 IRQ_TYPE_EDGE_RISING>;
		goodix,reset_gpio = <&tlmm 20 GPIO_ACTIVE_LOW>;
		goodix,gpio_vdd = <&pm660l_gpios 5 GPIO_ACTIVE_HIGH>;
		goodix,irq_gpio = <&tlmm 72 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default", "sleep";
		pinctrl-0 = <&goodix_reset_active &goodix_irq_active>;
		pinctrl-1 = <&goodix_reset_sleep &goodix_irq_sleep>;
		status = "okay";
	};
};

/*add for SAR SENSOR*/

&i2c_2 {
	semtech@28 {
		status = "disabled";
	};
};

&i2c_4 {
	status = "okay";
};

&i2c_7 {
	/* for P/L Sensor */
	status = "okay";
	stk@48 {
		compatible = "stk,stk3x1x";
		reg = <0x48>;
		interrupt-parent = <&tlmm>;
		interrupts = <45 IRQ_TYPE_EDGE_FALLING>;
		vdd-supply = <&pm660l_l3>;
		vio-supply = <&pm660_l14>;
		stk,irq-gpio = <&tlmm 45 0x02>;
		pinctrl-names = "psensor_active", "psensor_suspend";
		pinctrl-0 = <&psensor_int_active>;
		pinctrl-1 = <&psensor_int_suspend>;
		stk,state-reg = <0x00>;
		stk,psctrl-reg = <0x71>;
		stk,alsctrl-reg = <0x3A>;
		stk,ledctrl-reg = <0x7F>;
		stk,wait-reg = <0x1F>;
		stk,ps-thdh = <150>;
		stk,ps-thdl = <100>;
		stk,transmittance = <1100>;
		stk,use-fir;
		stk,ps-gain = <4>;
		stk,als-gain = <64>;
	};
};
